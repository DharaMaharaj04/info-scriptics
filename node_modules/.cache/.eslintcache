     <Route exact path='/salesforce_marketing' component={SalesforceMarketingCloud} />\r\n            <Route exact path='/salesforce_studio' component={SalesforceInteractionStudio} />\r\n            <Route exact path='/salesforce_service' component={SalesforceServiceCloud} />\r\n            <Route exact path='/salesforce-bussinte' component={SaleforceBusinessIntelligence} />\r\n            <Route exact path='/blogs' component={Blogs} />\r\n            <Route exact path='/blog-inner' component={BlogInner} />\r\n            <Route exact path='/blackberry-cylance-defends' component={BlackberryCylanceDefends} />\r\n            <Route component={Page404} />\r\n           \r\n          </Switch>\r\n        <Footer/>\r\n      </Router>\r\n    </div>\r\n  );\r\n}\r\nexport default App;\r\n","D:\\Scriptics_new\\info-scriptics\\src\\reportWebVitals.js",[],"D:\\Scriptics_new\\info-scriptics\\src\\components\\Header.js",[],"D:\\Scriptics_new\\info-scriptics\\src\\components\\Footer.js",["328"],"import React from 'react';\r\nimport emailjs from 'emailjs-com';\r\nfunction Footer() {\r\n\r\n    function sendEmail(e) {\r\n        e.preventDefault();\r\n        emailjs.sendForm('service_3cgd93a', 'template_dapptnn', e.target, 'user_85McB6BS84C9WdDmfL0pV')\r\n          .then((result) => {\r\n              console.log(result.text + 'mail send');\r\n              alert(\"Your subscription has been sent\");\r\n          }, (error) => {\r\n              console.log(error.text);\r\n          });\r\n          e.target.reset();\r\n    }\r\n\r\n    return (\r\n        <div id=\"footer\">\r\n            <footer>\r\n                <article className=\"ftr-1\">\r\n                    <div className=\"container pt50 pb50\">\r\n                        <div className=\"row\">\r\n                            <div className=\"col-lg-3 col-md-3 col-sm-4 col-12 col-xs-12\">\r\n                                <h3 className=\"ftr-head mt-xs-20\">Company</h3>\r\n                                <ul className=\"list-unstyled footer-txt\">\r\n                                    <li><a aria-label=\"Go to Navigate your next Page\" href=\"/about-us/#work-stratery\" title=\"Future Technology\">Future Technology</a></li>\r\n                                    <li><a aria-label=\"Go to About Scriptics Page\" href=\"/about-us\" title=\"About Scriptics\">AboutUs</a></li>\r\n                                    <li><a aria-label=\"Go to Careers Page\" href=\"/contact/#contact-us\" title=\"Careers\">Careers</a></li>\r\n                                    <li><a aria-label=\"Go to ESG Page\" href=\"/about-us/#technology-we-follow\" title=\"CustomerService\">CustomerService</a></li>\r\n                                </ul>\r\n                            </div>\r\n                            <div className=\"col-lg-3 col-md-3 col-sm-4 col-12 col-xs-12\">\r\n                                <h3 className=\"ftr-head mt-xs-20\">Discover</h3>\r\n                                <ul className=\"list-unstyled footer-txt\">\r\n                                    <li><a aria-label=\"Go to Navigate your next Page\" href=\"/#he_service\" title=\"Service\">Services</a></li>\r\n                                    <li><a aria-label=\"Go to ESG Page\" href=\"/#he_industries\" title=\"Industries\">Industries</a></li>\r\n                                    <li><a aria-label=\"Go to Investors Page\" href=\"/#he_cloud\" title=\"Cloud services\">Cloud services</a></li>\r\n                                </ul>\r\n                            </div>\r\n                            <div className=\"clearfix visible-sm\"></div>\r\n                            <div className=\"col-lg-3 col-md-6 col-sm-6 col-12 col-xs-12\">\r\n                                <h3 className=\"ftr-head mt-sm-20\">Connect with us</h3>\r\n                                <ul className=\"list-inline footer-txt\">\r\n                                    <li className=\"list-inline-item\">\r\n                                        <a aria-label=\"Follow us on Twitter\" title=\"Follow us on Twitter\" target=\"_blank\" href=\"https://twitter.com/scripticstech\" rel=\"noopener noreferrer\">\r\n                                            <img src=\"/assets/img/twitter.svg\" width=\"20\" height=\"20\" alt=\"Twitter\" />\r\n                                        </a>\r\n                                    </li>\r\n                                    <li className=\"list-inline-item\">\r\n                                        <a aria-label=\"Follow us on Facebook\" title=\"Follow us on Facebook\" target=\"_blank\" href=\"https://www.facebook.com/scripticsinc/\" rel=\"noopener noreferrer\"> \r\n                                            <img src=\"/assets/img/facebook.svg\" width=\"20\" height=\"20\" alt=\"Facebook\" />\r\n                                        </a>\r\n                                    </li>\r\n                                    <li className=\"list-inline-item\">\r\n                                        <a aria-label=\"Follow us on LinkedIn\" title=\"Follow us on LinkedIn\" target=\"_blank\" href=\"https://www.linkedin.com/company/scripticstechs/\" rel=\"noopener noreferrer\"> \r\n                                            <img src=\"/assets/img/linkedin.svg\" width=\"20\" height=\"20\" alt=\"LinkedIn\" />\r\n                                        </a>\r\n                                    </li>\r\n                                    <li className=\"list-inline-item\">\r\n                                        <a aria-label=\"Follow us on YouTube\" title=\"Follow us on YouTube\" target=\"_blank\" href=\"https://www.youtube.com/@scripticstechnologies6312/\" rel=\"noopener noreferrer\">\r\n                                            <img src=\"/assets/img/youtube.svg\" width=\"20\" height=\"20\" alt=\"Youtube\" />\r\n                                        </a>\r\n                                    </li>\r\n                                </ul>\r\n                            </div>\r\n                            <div className=\"col-lg-3 col-md-6 col-sm-6 col-12 col-xs-12\">\r\n                                <div className=\"footet-heading\">\r\n                                    <h4>Stay in the know with our newsletter</h4>\r\n                                    <div className='ftr-1-email'>\r\n                                        <form id=\"footer-form\" onSubmit={sendEmail}>\r\n                                            <input type=\"text\" className=\"footer-email\" placeholder=\"Your Email here\" name=\"email\" required/><span className=\"email-tip\"></span>\r\n                                            <button className=\"footer-btn\">Subscribe Now <i className=\"fa fa-arrow-right\"></i></button>\r\n                                        </form>\r\n                                    </div>    \r\n                                </div>\r\n                                <div className=\"footet-heading\">\r\n                                   \r\n                                </div>\r\n                            </div>\r\n                    \r\n                        </div>\r\n                    </div>        \r\n                </article>\r\n            </footer>\r\n            <div id=\"scrollToTop\">\r\n                <img src=\"/assets/img/arrow_up.png\" href=\"#\" id=\"scroll\" />\r\n            </div>\r\n        </div>\r\n    )            \r\n}\r\n\r\nexport default Footer","D:\\Scriptics_new\\info-scriptics\\src\\pages\\AboutUs.js",["329","330","331","332","333","334","335","336"],"D:\\Scriptics_new\\info-scriptics\\src\\pages\\AmazonQuickSight.js",["337","338","339","340","341"],"D:\\Scriptics_new\\info-scriptics\\src\\pages\\AmazonEKS.js",["342","343","344","345","346"],"D:\\Scriptics_new\\info-scriptics\\src\\pages\\ApplicationModernization.js",["347","348","349","350","351"],"D:\\Scriptics_new\\info-scriptics\\src\\pages\\AwsElemental.js",["352","353","354","355","356"],"import React, { Component } from 'react';\r\nimport { Helmet } from 'react-helmet';\r\nimport OwlCarousel from 'react-owl-carousel';\r\nimport 'owl.carousel/dist/assets/owl.carousel.css';\r\nimport 'owl.carousel/dist/assets/owl.theme.default.css';\r\n\r\nexport default class AwsElemental extends Component {\r\n    render() {\r\n\r\n        const options = {\r\n            loop: true,\r\n            margin: 0,\r\n            items: 1,\r\n            autoplay: true,\r\n            dots: true,\r\n            autoplay: true,\r\n            dots: true\r\n        };   \r\n\r\n        return (\r\n            <div className=\"service-page\">\r\n                <Helmet>\r\n                    <body id=\"page-cloud\" />\r\n                </Helmet>\r\n                <div className=\"spacer\"></div>\r\n                <section className='srv-main'>\r\n                    <OwlCarousel className=\"owl-theme\" {...options} >\r\n                        <div className='slide-1'>  \r\n                            <div className='slide-img'>\r\n                                <img src=\"/assets/img/employee-experience-lead.png\" />\r\n                                <div className='slider-overlay-amethyst'></div>\r\n                            </div>\r\n                            <div className='caption'>\r\n                                <div className='container'>\r\n                                    <div className='row'>\r\n                                        <div className='col-lg-7 col-md-7 col-sm-12 col-xs-12'>\r\n                                            <div className='slide_content'>\r\n                                                <h2 className=\"h2-slide white-color mb-xs-10\">MAKE THE FIRST MOVE WITH STRATEGY & CONSULTING</h2>\r\n                                               \r\n                                            </div>\r\n                                        </div>\r\n                                    </div> \r\n                                </div>     \r\n                            </div>      \r\n                        </div>\r\n                        <div className='slide-2'>\r\n                            <div className='slide-img'>\r\n                                <img src=\"/assets/img/cloud-data-cultivates-cs-lead.png\" />\r\n                                <div className='slider-overlay-amethyst'></div>\r\n                            </div>\r\n                            <div className='caption'>\r\n                                <div className='container'>\r\n                                    <div className='row'>\r\n                                        <div className='col-lg-7 col-md-7 col-sm-12 col-xs-12'>\r\n                                            <div className='slide_content'>\r\n                                                <h2 className=\"h2-slide white-color mb-xs-10\">INITIAL DESIGN WITH INTERACTIVE TECHNOLOGY</h2>\r\n                                                \r\n                                            </div>\r\n                                        </div>\r\n                                    </div>  \r\n                                </div>\r\n                            </div>    \r\n                        </div>\r\n                        <div className='slide-3'>\r\n                            <div className='slide-img'>\r\n                                <img src=\"/assets/img/enterprise-agility-lead-mob.jpg\" />\r\n                                <div className='slider-overlay-amethyst'></div>\r\n                            </div>\r\n                            <div className='caption'>\r\n                                <div className='container'>\r\n                                    <div className='row'> \r\n                                        <div className='col-lg-7 col-md-7 col-sm-12 col-xs-12 fadeInUp  Wow from-bottom'>\r\n                                            <div className='slide_content'>\r\n                                                <h2 className=\"h2-slide white-color mb-xs-10\">SCRIPTICS, AI FOR GAMING EXPERIENCE</h2>\r\n                                                \r\n                                            </div>\r\n                                        </div>\r\n                                    </div> \r\n                                </div>    \r\n                            </div>\r\n                        </div>\r\n                    </OwlCarousel>\r\n                </section>\r\n                <section className=\"srv-img\" style={{background:`url(/assets/img/cloud_service-1.jpg) no-repeat center`}}>\r\n                </section>\r\n                <section className=\"srv-content\">\r\n                    <div className=\"container\">\r\n                        <div className=\"row\">\r\n                        <div className=\"col-12 col-sm-12 col-md-12 col-lg-12\">\r\n                                <div className=\"srv-info\">\r\n                                    <h3 className=\"srv-info\">Bring Your Creation to Life. Optimize Your Production. Implement Everywhere.</h3>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"col-12 col-sm-12 col-md-6 col-1g-6\">\r\n                                <div className=\"srv-info\">\r\n                                    <p> Scriptics combines the vast capabilities of the Amazon Web Services cloud with cutting-edge video expertise to enable a platform for media innovation and deliver your valuable content to life.</p>\r\n                                    <p>Scriptics has the #1 Internal AWS Partner Score in the US. Scriptics partnered with Amazon Web Services to deliver best-in-class services to your company in any phase of your cloud adaptation journey. We are among the select AWS Elemental partners. We have AWS media experts who provide professional services to our customers.</p>\r\n                                    <p>“We Keep our Heads in the Cloud So You Don’t Have To.”</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"col-12 col-sm-12 col-md-6 col-1g-6\">\r\n                                <img className=\"srv-con-img\" src=\"/assets/img/network-cloud.jpg\" alt=\"AI & Automation icon\" style={{height:300,width:'100%'}}/>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section>\r\n                <section className=\"capability cloud_pro1\">\r\n                    <div className=\"container\">\r\n                        <div className=\"row\">\r\n                            <div className=\"col-12 col-sm-12 col-md-12 col-lg-12\">\r\n                                <h3 className=\"text-center cloud_title\">Products</h3>\r\n                                <p className=\"text-center white-color\">Scriptics provides the latest solutions for the following AWS media services:</p>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <h3 className=\"text-center cloud_text_head\">Media Connect</h3>\r\n                                    <p>AWS Elemental MediaConnect is a high-quality transport service for live video between broadcasters and content owners using the cloud and fiber-connections.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Mediaconvert</h3>\r\n                                    </div>\r\n                                    <p>Easily create video on-demand (VOD) content for broadcast and multiscreen delivery at scale with AWS Elemental MediaConvert, a file-based video transcoding service with broadcast-grade features.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Medialive</h3>\r\n                                    </div>\r\n                                    <p>Create high-quality video streams for delivery to broadcast televisions and internet-connected multiscreen devices with AWS Elemental MediaLive is a broadcast-grade live video processing service.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">AWS Elemental Mediapackage</h3>\r\n                                    </div>\r\n                                    <p>Prepare and protect your video for delivery over the internet from a single video input. AWS Elemental MediaPackage creates video streams formatted to play across a wide range of devices.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Mediastore</h3>\r\n                                    </div>\r\n                                    <p>Deliver live streaming video content with AWS Elemental MediaStore, an AWS storage service optimized for media that gives you performance, consistency, and low latency.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Mediatailor</h3>\r\n                                    </div>\r\n                                    <p>A channel assembly and personalized service to create linear OTT channels using existing video content and monetize those channels, live-streams, and VOD content with personalized advertising.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section>\r\n                <section className=\"srv-content\">\r\n                    <div className=\"container\">\r\n                        <div className=\"row\">\r\n                            <div className=\"col-12 col-sm-12 col-md-12 col-1g-12\">\r\n                                <div className=\"text-center\">\r\n                                    <h3>Enter the Future of Media & Entertainment with Scriptics.</h3>\r\n                                    <p>Transform content production, media supply chain broadcasts, direct-to-consumer & streaming analytics with the most purpose-built capabilities of any cloud.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section>            \r\n                <section className=\"faq\">\r\n                    <div className=\"container\">\r\n                    <div className=\"row\">\r\n                            <div className=\"col-12 col-lg-12 col-md-12 col-sm-12 text-center\" style={{paddingTop:50,paddingBottom:20}}>\r\n                                <h2>On-Premises</h2>\r\n                            </div>\r\n                        </div>\r\n                        <div className=\"panel-group\" id=\"accordion\" role=\"tablist\" aria-multiselectable=\"true\">\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"headingOne\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapseOne\" aria-expanded=\"true\" aria-controls=\"collapseOne\">\r\n                                        Live\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapseOne\" className=\"panel-collapse collapse in\" role=\"tabpanel\" aria-labelledby=\"headingOne\">\r\n                                    <div className=\"panel-body\">\r\n                                    Encode live video on-premises for events and 24/7 streams with AWS Elemental Live. Convert inputs into live outputs for broadcast and multiscreen video delivery.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"headingTwo\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapseTwo\" aria-expanded=\"false\" aria-controls=\"collapseTwo\">\r\n                                        Server\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapseTwo\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\">\r\n                                    <div className=\"panel-body\">\r\n                                    Prepare file-based video on-premises for on-demand distribution with AWS Elemental Server.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"headingThree\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapseThree\" aria-expanded=\"false\" aria-controls=\"collapseThree\">\r\n                                        Conductor\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapseThree\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\r\n                                    <div className=\"panel-body\">\r\n                                    Simplify management for on-premise video encoding and manage video networks for live and on-demand content with AWS Elemental Conductor.\r\n                                    </div>\r\n                                </div>    \r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"heading4\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\r\n                                        Link\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapse4\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"heading4\">\r\n                                    <div className=\"panel-body\">\r\n                                    Link HD for 1080p HD video and UHD for 4K HDR video with AWS Elemental Link Device Family.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>    \r\n                    </div>        \r\n                </section>\r\n            </div>                \r\n        )\r\n    }\r\n}\r\n","D:\\Scriptics_new\\info-scriptics\\src\\pages\\Automative.js",["357","358","359","360","361"],"D:\\Scriptics_new\\info-scriptics\\src\\pages\\AIAutomation.js",["362","363","364","365","366","367","368","369","370"],"D:\\Scriptics_new\\info-scriptics\\src\\pages\\AmazonRelationalDatabaseService.js",["371","372","373","374","375"],"import React, { Component } from 'react';\r\nimport { Helmet } from 'react-helmet';\r\nimport OwlCarousel from 'react-owl-carousel';\r\nimport 'owl.carousel/dist/assets/owl.carousel.css';\r\nimport 'owl.carousel/dist/assets/owl.theme.default.css';\r\n\r\nexport default class AmazonRelationalDatabaseService extends Component {\r\n    render() {\r\n\r\n        const options = {\r\n            loop: true,\r\n            margin: 0,\r\n            items: 1,\r\n            autoplay: true,\r\n            dots: true,\r\n            autoplay: true,\r\n            dots: true\r\n        };    \r\n\r\n\r\n        return (\r\n            <div className=\"service-page\">\r\n            <Helmet>\r\n                <body id=\"page-cloud\" />\r\n            </Helmet>\r\n                <div className=\"spacer\"></div>\r\n                <section className='srv-main'>\r\n                    <OwlCarousel className=\"owl-theme\" {...options} >\r\n                        <div className='slide-1'>  \r\n                            <div className='slide-img'>\r\n                                <img src=\"/assets/img/employee-experience-lead.png\" />\r\n                                <div className='slider-overlay-amethyst'></div>\r\n                            </div>\r\n                            <div className='caption'>\r\n                                <div className='container'>\r\n                                    <div className='row'>\r\n                                        <div className='col-lg-7 col-md-7 col-sm-12 col-xs-12'>\r\n                                            <div className='slide_content'>\r\n                                                <h2 className=\"h2-slide white-color mb-xs-10\">MAKE THE FIRST MOVE WITH STRATEGY & CONSULTING</h2>\r\n                                                <a className=\"btn btn-shutter-more text-uppercase\" href=\"/\">explore</a>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div> \r\n                                </div>     \r\n                            </div>      \r\n                        </div>\r\n                        <div className='slide-2'>\r\n                            <div className='slide-img'>\r\n                                <img src=\"/assets/img/cloud-data-cultivates-cs-lead.png\" />\r\n                                <div className='slider-overlay-amethyst'></div>\r\n                            </div>\r\n                            <div className='caption'>\r\n                                <div className='container'>\r\n                                    <div className='row'>\r\n                                        <div className='col-lg-7 col-md-7 col-sm-12 col-xs-12'>\r\n                                            <div className='slide_content'>\r\n                                                <h2 className=\"h2-slide white-color mb-xs-10\">INITIAL DESIGN WITH INTERACTIVE TECHNOLOGY</h2>\r\n                                                <a className=\"btn btn-shutter-more text-uppercase\" href=\"/\">explore</a>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>  \r\n                                </div>\r\n                            </div>    \r\n                        </div>\r\n                        <div className='slide-3'>\r\n                            <div className='slide-img'>\r\n                                <img src=\"/assets/img/enterprise-agility-lead-mob.jpg\" />\r\n                                <div className='slider-overlay-amethyst'></div>\r\n                            </div>\r\n                            <div className='caption'>\r\n                                <div className='container'>\r\n                                    <div className='row'> \r\n                                        <div className='col-lg-7 col-md-7 col-sm-12 col-xs-12'>\r\n                                            <div className='slide_content'>\r\n                                                <h2 className=\"h2-slide white-color mb-xs-10\">SCRIPTICS, AI FOR GAMING EXPERIENCE</h2>\r\n                                                <a className=\"btn btn-shutter-more text-uppercase\" href=\"/\">explore</a>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div> \r\n                                </div>    \r\n                            </div>\r\n                        </div>\r\n                    </OwlCarousel>\r\n                </section>\r\n                <section className=\"srv-img\" style={{background:`url(/assets/img/cloud_service-1.jpg) no-repeat center`}}>\r\n                </section>\r\n                <section className=\"srv-content\">\r\n                    <div className=\"container\">\r\n                        <div className=\"row\">\r\n                            <div className=\"col-12 col-sm-12 col-md-12 col-lg-12 fadeInUp animated from-right\">\r\n                                <div className=\"srv-info\">\r\n                                    <h3>Set up, operate, and scale a cloud-based relational database with just a few clicks.</h3>\r\n                                    <h3>What is Amazon RDS?</h3>\r\n                                    <p className=\"srv-info\">Amazon Relational Database Service (Amazon RDS) makes it easy to set up, operate, and scale a relational database in the cloud. Automate time-consuming tasks such as hardware provisioning, database setup, patching and backups. Focus on your applications with cost savings and resizable capacity.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"col-12 col-sm-12 col-md-6 col-1g-6 fadeInUp animated from-right\">\r\n                                <div className=\"srv-info\">\r\n                                    <p>Optimized for memory, performance I/O and Amazon RDS provides you with six familiar database engines to choose from, including: Amazon Aurora, PostgreSQL, MySQL, MariaDB, Oracle Database, SQL Server, and AWS Database Migration Service</p>\r\n                                    <p>Take full advantage of Amazon RDS with Scriptics. Easily migrate or replicate your existing databases to Amazon RDS.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"col-12 col-sm-12 col-md-6 col-1g-6 fadeInUp animated from-left\">\r\n                                <img className=\"srv-con-img\" src=\"/assets/img/network-cloud.jpg\" alt=\"AI & Automation icon\" style={{height:300,width:'100%'}}/>\r\n                            </div>\r\n                            \r\n                        </div>\r\n                    </div>\r\n                </section>\r\n                <section className=\"capability cloud_pro\">\r\n                    <div className=\"container\">\r\n                        <div className=\"row\">\r\n                            <div className=\"srv-capability-box col-12 col-lg-4 fadeInUp  Wow from-bottom\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <h3 className=\"text-center cloud_text_head\">Easy To Administer</h3>\r\n                                    <p>Easily go from project to conception to deployment with Amazon RDS. No need for infrastructure provisioning or installing and maintaining database software.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4 fadeInUp  Wow from-bottom\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Highly Scalable</h3>\r\n                                    </div>\r\n                                    <p>Easily scale your database’s compute and storage resources with a few mouse clicks or an API call, often with no downtime.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4 fadeInUp  Wow from-bottom\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Available and Durable</h3>\r\n                                    </div>\r\n                                    <p>Amazon RDS runs on the same reliable infrastructure used by other Amazon Web Services. In addition, Amazon Aurora provides performance on par with commercial databases at 1/10th the cost.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4 fadeInUp  Wow from-bottom\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Fast</h3>\r\n                                    </div>\r\n                                    <p>Amazon RDS supports the most demanding database applications. You can choose between two SSD-backed storage options: one optimized for high-performance OLTP applications, and the other for cost-effective general use. In addition, Amazon Aurora provides performance on par with commercial databases at 1/10th the cost.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4 fadeInUp  Wow from-bottom\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Inexpensive</h3>\r\n                                    </div>\r\n                                    <p>Pay very low rates for only the resources you use. Benefit from both On-Demand pricing options with no up-front long-term commitments, and lower hourly rates via our Reserved Instance pricing.</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"srv-capability-box col-12 col-lg-4 fadeInUp  Wow from-bottom\">\r\n                                <div className=\"capa_image_with_text cloud_head_with_text\">\r\n                                    <div className=\"capa_img\">\r\n                                        <h3 className=\"text-center cloud_text_head\">Secure</h3>\r\n                                    </div>\r\n                                    <p>Amazon RDS makes it easy to control network access to your database. Run your database instances in Amazon Virtual Private Cloud, which enables you to isolate your database instances.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section> \r\n                <section className=\"srv-content\">\r\n                    <div className=\"container\">\r\n                        <div className=\"row\">\r\n                            <div className=\"col-12 col-sm-12 col-md-12 col-lg-12\">\r\n                                <div className=\"srv-info\">\r\n                                    <h3 className='text-center'>Partner with Scriptics for your Competitive Advantage.</h3>\r\n                                    <p className=\"srv-info\">Scriptics has the #1 AWS Partner Score in the US. Partners with Amazon Web Services deliver best-in-class services to your company in any phase of your cloud adoption journey. This further includes industry focused data application and security, as well as automatic software upgrades. It’s extremely efficient and flexible with a short implementation time.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section>\r\n                <section className=\"faq\">\r\n                    <div className=\"container\">\r\n                    <div className=\"row\">\r\n                            <div className=\"col-12 col-lg-12 col-md-12 col-sm-12 text-center fadeInUp animated from-right\" style={{paddingTop:40,paddingBottom:20}}>\r\n                                <h2>How It Works</h2>\r\n                            </div>\r\n                        </div>\r\n                        <div className=\"panel-group\" id=\"accordion\" role=\"tablist\" aria-multiselectable=\"true\">\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"headingOne\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapseOne\" aria-expanded=\"true\" aria-controls=\"collapseOne\">\r\n                                         Purchasing\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapseOne\" className=\"panel-collapse collapse in\" role=\"tabpanel\" aria-labelledby=\"headingOne\">\r\n                                    <div className=\"panel-body\">\r\n                                    All steps are automated from procurement to payment.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"headingTwo\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapseTwo\" aria-expanded=\"false\" aria-controls=\"collapseTwo\">\r\n                                         Material Management\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapseTwo\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\">\r\n                                    <div className=\"panel-body\">\r\n                                    Manage inventory receipts, shipments, moves, and counts across your warehouses, suppliers, and customers.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"headingThree\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapseThree\" aria-expanded=\"false\" aria-controls=\"collapseThree\">\r\n                                        Orders and Sales\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapseThree\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\r\n                                    <div className=\"panel-body\">\r\n                                    Create quotes, book orders, manage materials, generate invoices, and collect cash.\r\n                                    </div>\r\n                                </div>    \r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"heading4\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\r\n                                        Project Mangement\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapse4\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"heading4\">\r\n                                    <div className=\"panel-body\">\r\n                                    Define, manage, track, and report on projects.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"heading5\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\r\n                                        Time Mangement\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapse5\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"heading5\">\r\n                                    <div className=\"panel-body\">\r\n                                    Record and manage employees’ and subcontractors’ time on each project, phase, and task.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"heading6\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\r\n                                        Manufacturing\r\n                                        </a>\r\n                                    </h4>\r\n                                </div>\r\n                                <div id=\"collapse6\" className=\"panel-collapse collapse\" role=\"tabpanel\" aria-labelledby=\"heading6\">\r\n                                    <div className=\"panel-body\">\r\n                                    Control manufacturing with material planning, production scheduling, and shop floor execution capabilities.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"panel panel-default\">\r\n                                <div className=\"panel-heading\" role=\"tab\" id=\"heading7\">\r\n                                    <h4 className=\"panel-title\">\r\n                                        <a className=\"collapsed\" role=\"button\" data-toggle=\"collapse\" data-parent=\"#accordion\" href=\"#collapse7\" aria-expande